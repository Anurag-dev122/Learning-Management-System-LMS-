{
  "name": "learning-management-system-lms",
  "version": "1.0.0",
  "description": "A comprehensive Learning Management System built in Node.js, SQLite, and React.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
